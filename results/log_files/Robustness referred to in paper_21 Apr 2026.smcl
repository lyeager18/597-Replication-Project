{com}. 
. 
. quietly sort original_sorting_order
{txt}
{com}. pause off
{txt}
{com}. set more on
{txt}
{com}. 
. display "Code has completed."
{res}Code has completed.
{txt}
{com}. display "Benjamini Krieger Yekutieli (2006) sharpened q-vals are in variable 'bky06_qval'"
{res}Benjamini Krieger Yekutieli (2006) sharpened q-vals are in variable 'bky06_qval'
{txt}
{com}. display "Sorting order is the same as the original vector of p-values"
{res}Sorting order is the same as the original vector of p-values
{txt}
{com}. 
. * Note: Sharpened FDR q-vals can be LESS than unadjusted p-vals when many hypotheses are rejected, because if you have many true rejections, then you can tolerate several false rejections too (this effectively just happens for p-vals that are so large that you are not going to reject them regardless).
. 
. mkmat bky06_qval, matrix(qval)          // save q-vals as a matrix
{res}{txt}
{com}. 
. 
. version 18.5            // return to current version
{txt}
{com}. 
{txt}end of do-file
LF_BL qvals for beta 1:
{res}
{txt}LF_BL_qval_b1[2,1]
    bky06_qval
r1 {res}       .583
{txt}r2 {res}  .36399999
{reset}LF_BL qvals for  beta 1 + beta 3:
{res}
{txt}LF_BL_qval_b13[2,1]
    bky06_qval
r1 {res}          1
{txt}r2 {res}          1
{reset}
{com}.                 restore
{txt}
{com}.                 
.                 * Re-run models and store scalars
.                 local i = 1     
{txt}
{com}.                 foreach hte of global hte_var {c -(}
{txt}  2{com}.                         
.                         * create a var with a standardized name for HTE var so that estimates 
.                         // show up in same row in table
.                         gen hte = `hte' if ``hte'_miss' == 0
{txt}  3{com}.                         
.                         local q = 1                     // row of q-val corresponding to outcome
{txt}  4{com}.                         foreach outcome of global hte_outcome {c -(}
{txt}  5{com}. 
.                                 reghdfe `outcome' treatment##hte ${c -(}controls_`hte'{c )-}, ///
>                                 absorb(randomization_cohort2 )  vce(cluster file_nbr)
{txt}  6{com}.                                 eststo `outcome'_hte`i'
{txt}  7{com}.                                 
.                                 * p-val - treatment 
.                                 test _b[1.treatment] =0
{txt}  8{com}.                                 estadd scalar b1 = r(p)
{txt}  9{com}.                                          
.                                 * p-val -  treatment + treatment x hte var
.                                 test _b[1.treatment] + _b[1.treatment#1.hte]=0
{txt} 10{com}.                                 estadd scalar b1_b3 = r(p)
{txt} 11{com}.                                 
.                                 * Store total effect for outcomes in Panel B                    
.                                 lincom 1.treatment + 1.treatment#1.hte                          
{txt} 12{com}.                                 local totaleff: di %9.3f `r(estimate)'
{txt} 13{com}.                                 if `r(p)' < 0.01 {c -(}
{txt} 14{com}.                                 local star "\sym{c -(}***{c )-}"
{txt} 15{com}.                                 {c )-}
{txt} 16{com}.                                 else if `r(p)' < 0.05 {c -(}
{txt} 17{com}.                                 local star "\sym{c -(}**{c )-}"
{txt} 18{com}.                                 {c )-}
{txt} 19{com}.                                 else if `r(p)' < 0.1 {c -(}
{txt} 20{com}.                                 local star "\sym{c -(}*{c )-}"
{txt} 21{com}.                                 {c )-}
{txt} 22{com}.                                 else {c -(}
{txt} 23{com}.                                         local star ""
{txt} 24{com}.                                 {c )-}
{txt} 25{com}.                                 estadd local total_eff_b  "`totaleff'`star'"
{txt} 26{com}.                                 local aux_se: display %5.3f `r(se)'
{txt} 27{com}.                                 estadd local total_eff_se "(`aux_se')"
{txt} 28{com}.                         
.                                 
.                                 * grab control means for each subgroup
.                                 sum `outcome' if e(sample) & treatment==0 & hte==0
{txt} 29{com}.                                 estadd scalar cmean_hte = r(mean)
{txt} 30{com}.                                 
.                                 * Q-values
.                                 estadd scalar qval_b1 = `hte'_qval_b1[`q',1]                    // beta 1
{txt} 31{com}.                                 estadd scalar qval_b13 = `hte'_qval_b13[`q',1]                  // beta 1 + beta 3
{txt} 32{com}.                                 local q = `q' + 1
{txt} 33{com}.                                 
. 
.                                 {c )-}
{txt} 34{com}.                                 
.                         local i = `i' + 1
{txt} 35{com}.                         drop hte
{txt} 36{com}.                         {c )-}
