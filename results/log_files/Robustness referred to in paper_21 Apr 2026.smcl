. * Write to latex
.                 esttab gen_policy_sw Combined_P1_1_likert P1_2_likert ///
>                 using "$output_rct/robustness/Alt_Table_A13_Likert.tex", ///
>                 label se nonotes keep( treatment) b(%9.3f) se(%9.3f) star(* 0.1 ** 0.05 *** 0.01) ///
>                 scalars("cmean Control mean" "b_cmean $\beta$/control mean" "pval P-value $\beta = 0$") ///
>                 mtitles("\shortstack{c -(}Index: Approval\\of Gender Policy{c )-}" ///
>                 "\shortstack{c -(}Government is\\working fast\\enough to give\\women same\\rights as men{c )-}" ///        
>                 "\shortstack{c -(}Feels the impact\\of changes that\\government is\\making to give\\women same rights{c )-}") ///
>                 mgroups("Index" "Index Components", pattern(1 1 0) ///
>                 prefix(\multicolumn{c -(}@span{c )-}{c -(}c{c )-}{c -(}) suffix({c )-}) span erepeat(\cmidrule(lr){c -(}@span{c )-})) ///
>                 replace fragment modelwidth(25) varwidth(25) nogaps
{res}{txt}(output written to {browse  `"C:/Users/lunaf/OneDrive/Documents/GitHub/597-Replication-Project/results/RCT/tables/robustness/Alt_Table_A13_Likert.tex"'})

