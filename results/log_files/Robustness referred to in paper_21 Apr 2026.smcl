>                         label se nogaps nobaselevels ///
>                         keep(*treatment *husb_influence_kids_original_BL) b(%9.3f) se(%9.3f) star(* 0.1 ** 0.05 *** 0.01) ///   
>                         mtitles("\shortstack{c -(}Started driver's\\training{c )-}" ///
>                         "\shortstack{c -(}Received\\license{c )-}" "\shortstack{c -(}Any driving\\in past month{c )-}" ///
>                         "\shortstack{c -(}Number of\\times left\\house in\\last 7 days{c )-}" ///
>                         "\shortstack{c -(}Share of\\trips made\\without male\\chaperone{c )-}" ///
>                         "\shortstack{c -(}Always travels\\with male\\chaperone{c )-}") ///
>                         varlabels(1.treatment "$\beta\textsubscript{c -(}1{c )-}$: Treatment" ///
>                         1.husb_influence_kids_original_BL "$\beta\textsubscript{c -(}2{c )-}$: Has husband/co-parent" ///
>                         1.treatment#1.husb_influence_kids_original_BL ///
>                         "$\beta\textsubscript{c -(}3{c )-}$: Treatment x Has husband/co-parent") ///
>                         replace  varwidth(25) modelwidth(12) fragment nonotes noobs
