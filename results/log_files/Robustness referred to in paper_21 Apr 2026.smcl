{com}. 
. 
. quietly sort original_sorting_order
{txt}
{com}. pause off
{txt}
{com}. set more on
{txt}
{com}. 
. display "Code has completed."
{res}Code has completed.
{txt}
{com}. display "Benjamini Krieger Yekutieli (2006) sharpened q-vals are in variable 'bky06_qval'"
{res}Benjamini Krieger Yekutieli (2006) sharpened q-vals are in variable 'bky06_qval'
{txt}
{com}. display "Sorting order is the same as the original vector of p-values"
{res}Sorting order is the same as the original vector of p-values
{txt}
{com}. 
. * Note: Sharpened FDR q-vals can be LESS than unadjusted p-vals when many hypotheses are rejected, because if you have many true rejections, then you can tolerate several false rejections too (this effectively just happens for p-vals that are so large that you are not going to reject them regardless).
. 
. mkmat bky06_qval, matrix(qval)          // save q-vals as a matrix
{res}{txt}
{com}. 
. 
. version 18.5            // return to current version
{txt}
{com}. 
{txt}end of do-file

{com}.                         
.                         * To check these:
.                         di "qvals for beta 1:"
{res}qvals for beta 1:
{txt}
{com}.                         mat list qval_b1
{res}
{txt}qval_b1[2,1]
    bky06_qval
r1 {res}          1
{txt}r2 {res}          1
{reset}
{com}.                         di "qvals for  beta 1 + beta 3:"
{res}qvals for  beta 1 + beta 3:
{txt}
{com}.                         mat list qval_b13
{res}
{txt}qval_b13[2,1]
    bky06_qval
r1 {res}  .48300001
{txt}r2 {res}       .042
{reset}
{com}. 
.                 restore
{txt}
{com}.                 
.                 * (3) RE-RUN  MODELS FOR HAS HUSBAND/CO-PAR - STORE ESTIMATES
.                 local q = 1             // row of q-val corresponding to outcome
{txt}
{com}.                 foreach outcome of global hte_outcome {c -(}
{txt}  2{com}.                 
.                         reghdfe `outcome' treatment##i.husb_influence_kids  $controls_HTEhusb, ///
>                                 absorb(randomization_cohort2)  vce(cluster file_nbr)
{txt}  3{com}.                         eststo `outcome'_inf
{txt}  4{com}.                         
.                         * p-val - treatment 
.                         test _b[1.treatment] =0
{txt}  5{com}.                         estadd scalar b1 = r(p)
{txt}  6{com}.                                          
.                         * p-val -  treatment + treatment x has husband/co-parent
.                         test _b[1.treatment] + _b[1.treatment#1.husb_influence_kids]=0
{txt}  7{com}.                         estadd scalar b1_b3 = r(p)
{txt}  8{com}.                         
.                         * Store total effect for outcomes in Panel B                    
.                         lincom 1.treatment + 1.treatment#1.husb_influence_kids                          
{txt}  9{com}.                         local totaleff: di %9.3f `r(estimate)'
{txt} 10{com}.                         if `r(p)' < 0.01 {c -(}
{txt} 11{com}.                         local star "\sym{c -(}***{c )-}"
{txt} 12{com}.                         {c )-}
{txt} 13{com}.                         else if `r(p)' < 0.05 {c -(}
{txt} 14{com}.                         local star "\sym{c -(}**{c )-}"
{txt} 15{com}.                         {c )-}
{txt} 16{com}.                         else if `r(p)' < 0.1 {c -(}
{txt} 17{com}.                         local star "\sym{c -(}*{c )-}"
{txt} 18{com}.                         {c )-}
{txt} 19{com}.                         else {c -(}
{txt} 20{com}.                                 local star ""
{txt} 21{com}.                         {c )-}
{txt} 22{com}.                         estadd local total_eff_b  "`totaleff'`star'"
{txt} 23{com}.                         local aux_se: display %5.3f `r(se)'
{txt} 24{com}.                         estadd local total_eff_se "(`aux_se')"
{txt} 25{com}.                 
.                         
.                         * grab control means for each subgroup
.                         sum `outcome' if e(sample) & treatment==0 & husb_influence_kids==0
{txt} 26{com}.                         estadd scalar cmean_hte = r(mean)
{txt} 27{com}.                                  
.                         * Q-values
.                         estadd scalar qval_b1 = qval_b1[`q',1]                  // beta 1
{txt} 28{com}.                         estadd scalar qval_b13 = qval_b13[`q',1]                // beta 1 + beta 3
{txt} 29{com}.                         local q = `q' + 1
{txt} 30{com}.                 {c )-}
