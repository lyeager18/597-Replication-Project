. * Write to latex
. 
.         * interacted with husb/co-par            
.         esttab  $outcomes_hte using ///
>                 "$output_rct/robustness/Working and ability to spend_HTE_husb-co-par_`c(current_date)'.tex", ///
>                 label se nogaps nobaselevels ///
>                 keep(*treatment *husb_influence_kids) b(%9.3f) se(%9.3f) star(* 0.1 ** 0.05 *** 0.01) ///       
>                 mtitles("\shortstack{c -(}Working,\\able to spend{c )-}" ///
>                         "\shortstack{c -(}Working,\\not able to\\spend{c )-}" ///
>                         "\shortstack{c -(}Not working,\\able to spend{c )-}" ///
>                         "\shortstack{c -(}Not working,\\not able to\\spend{c )-}") ///
>                 varlabels(1.treatment "$\beta\textsubscript{c -(}1{c )-}$: Treatment" ///
>                         1.husb_influence_kids "$\beta\textsubscript{c -(}2{c )-}$: Has husband/co-parent" ///
>                         1.treatment#1.husb_influence_kids ///
>                 "$\beta\textsubscript{c -(}3{c )-}$: Treatment x Has husband/co-parent") ///
>                 replace  varwidth(25) modelwidth(12) fragment nonotes noobs
{res}{txt}{p 0 4 2}
