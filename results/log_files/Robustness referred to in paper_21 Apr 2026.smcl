{com}.         do              "$rep_code/tables/Robustness and stats referred to in paper/Alt_TA17.do"
{txt}
{com}. /*******************************************************************************
> ********************************************************************************
> ********************************************************************************
> 
> Purpose:        Robustness      -       Alternate Table A17; robustness to including 
>                                                         individual marital status dummies as controls
> 
> * Table Footnotes: This is an alternate version of Table A17, where we include
> marital status dummies as controls (they are left out in Table A17 due to 
> collinearity with Has Husband/Co-Parent). Both columns include individual and 
> household controls: age (above median dummy), education level (less than a high 
> school degree), household size (number of members), number of cars owned (indicators 
> for one car and for more than one car), an indicator for baseline labor force 
> participation, and strata fixed effects. SEs are clustered at household level. 
> We replace missing control values with 0 and include missing dummies for each, 
> except for the interaction controls. * p < 0.1 ** p < 0.05 *** p < 0.01
> ********************************************************************************
> ********************************************************************************
> ********************************************************************************/
. eststo clear
{txt}
{com}. 
. * RUN THESE DO FILES FIRST:
. 
.         do "$rep_code/1 - Pull in data.do"
{txt}
{com}. /*******************************************************************************
> ********************************************************************************
> ********************************************************************************
> 
> Purpose:                Pull in dataset for paper tables and figures; this dataset 
>                                 combines all three waves and is the final cleaned version. It is 
>                                 in wide format (sample size = 606)
>                                 
> ********************************************************************************
> ********************************************************************************
> *******************************************************************************/
. 
. * Pull in final dataset
. use  "$data/RCT wave 3/Final/Combined_allwaves_final.dta", clear
{txt}
{com}. 
. 
{txt}end of do-file

{com}.         do "$rep_code/2 - Setting regression controls.do"
{txt}
{com}. /*******************************************************************************
> ********************************************************************************
> ********************************************************************************
> 
> Purpose:                Controls for regressions (where missings have been moved to 0)
>                                 
> ********************************************************************************
> ********************************************************************************
> *******************************************************************************/
. 
. // NOTE:        DECISION TO BE MADE ON WHETHER TO UPDATE MARITAL STATUS CONTROLS TO MATCH
. //                      NEW CATEGORIES FOR HTE
. 
. *       Main models
. 
. global  controls age_med_BL_control miss_age_PAP edu_nohs_BL_control miss_edu_category ///
>                 married_control single_control widowed_control miss_relationship household_size_control ///
>                 miss_household_size one_car_control mult_cars_control miss_cars LF_BL_control miss_LF_BL
{txt}
{com}.                 
. * HTE with 'has husband/co-parent' (drops marital status dummies)
. 
. global  controls_HTEhusb age_med_BL_control miss_age_PAP edu_nohs_BL_control miss_edu_category ///
>                 household_size_control ///
>                 miss_household_size one_car_control mult_cars_control miss_cars LF_BL_control miss_LF_BL
{txt}
{com}.                 
. * HTE with BL LFP (drops LF_BL_control)
. 
. global  controls_LF_BL age_med_BL_control miss_age_PAP edu_nohs_BL_control miss_edu_category ///
>                 married_control single_control widowed_control miss_relationship household_size_control ///
>                 miss_household_size one_car_control mult_cars_control miss_cars
{txt}
{com}.                 
. * HTE with median age (drops age_med_BL_control)
. 
. global  controls_age_med_BL edu_nohs_BL_control miss_edu_category ///
>                 married_control single_control widowed_control miss_relationship household_size_control ///
>                 miss_household_size one_car_control mult_cars_control miss_cars LF_BL_control miss_LF_BL
{txt}
{com}.                 
. * HTE with edu (drops edu_nohs_BL_control)
.                 
. global  controls_edu_nohs_BL age_med_BL_control miss_age_PAP ///
>                 married_control single_control widowed_control miss_relationship household_size_control ///
>                 miss_household_size one_car_control mult_cars_control miss_cars LF_BL_control miss_LF_BL
{txt}
{com}.                 
. * HTE robustness to interacting treatment with baseline characteristics
. global  controls_BLcharinteract household_size_control ///
>                 miss_household_size one_car_control mult_cars_control miss_cars LF_BL_control miss_LF_BL
{txt}
{com}. 
. 
. 
. 
. 
{txt}end of do-file

{com}.         do "$rep_code/3 - Imputation for controls.do"
{txt}
{com}. /*******************************************************************************
> ********************************************************************************
> ********************************************************************************
> 
> Purpose:                Imputation for regression control variables (moving missings to 0)
>                                 
> ********************************************************************************
> ********************************************************************************
> *******************************************************************************/
. 
. 
. // NOTES: We will replace missing values for control variables with the sample mean
. // We have no missing values for: employed_BL   
. // Missing 1 from BLsearch, causing missing for unemployed_BL
. // Missing 1 from age (and age_4group)
. // Missing 19 from household_size
. // Missing 4 from marital group
. // Missing 12 from edu_category
. // Missing 17 from cars
. 
. 
. 
. * age (PAP version)
. gen miss_age_PAP = 0
{txt}
{com}. replace miss_age_PAP = 1 if age_med_BL==.
{txt}(1 real change made)

{com}. lab var miss_age_PAP "Missing value for age (PAP version)"
{txt}
{com}. 
. gen age_med_BL_control = age_med_BL
{txt}(1 missing value generated)

{com}. replace age_med_BL_control = 0 if age_med_BL==.
{txt}(1 real change made)

{com}. 
. 
. * household_size
. gen miss_household_size = 0
{txt}
{com}. replace miss_household_size = 1 if household_size==.
{txt}(19 real changes made)

{com}. lab var miss_household_size "Missing value for household_size"
{txt}
{com}. 
. gen household_size_control = household_size
{txt}(19 missing values generated)

{com}. replace household_size_control = 0 if household_size==.
{txt}(19 real changes made)

{com}. 
. 
. * Cars
. 
.         * create one missing tag(since missing for the same people)
.         gen miss_cars = 0
{txt}
{com}.         replace miss_cars = 1 if cars==.
{txt}(17 real changes made)

{com}.         lab var miss_cars "Missing value for cars"
{txt}
{com}.         
.         * dummy for one car
.         gen one_car_control = one_car
{txt}(17 missing values generated)

{com}.         replace one_car_control = 0 if one_car==.
{txt}(17 real changes made)

{com}.         
. 
.         * dummy for 2+ cars
.         gen mult_cars_control = mult_cars
{txt}(17 missing values generated)

{com}.         replace mult_cars_control = 0 if mult_cars==.
{txt}(17 real changes made)

{com}. 
.         
.         
. * Relationship status (updated categories)
. 
.         * create one missing tag (since missing for the same people)
.         gen miss_relationship   = 0
{txt}
{com}.         replace miss_relationship = 1 if rel_status_BL==.
{txt}(4 real changes made)

{com}.         lab var miss_relationship "Missing value for relationship status"
{txt}
{com}.         
.         
.         * married
.         gen married_control = married
{txt}(4 missing values generated)

{com}.         replace married_control = 0 if married==.
{txt}(4 real changes made)

{com}. 
. 
.         * divorced/separated
.         gen divorced_separated_control = divorced_separated
{txt}(4 missing values generated)

{com}.         replace divorced_separated_control = 0 if divorced_separated==.
{txt}(4 real changes made)

{com}. 
. 
.         * single
.         gen single_control = single
{txt}(4 missing values generated)

{com}.         replace single_control = 0 if single==.
{txt}(4 real changes made)

{com}. 
. 
. 
.         * widowed
.         gen widowed_control = widowed
{txt}(4 missing values generated)

{com}.         replace widowed_control = 0 if widowed==.
{txt}(4 real changes made)

{com}. 
.         
