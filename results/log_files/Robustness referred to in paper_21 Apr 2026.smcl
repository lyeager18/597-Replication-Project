>                 "\shortstack{c -(}Allowed to make\\purchase without\\permission{c )-}") ///
>                 fragment varwidth(25) modelwidth(15) replace
{res}{txt}(output written to {browse  `"C:/Users/lunaf/OneDrive/Documents/GitHub/597-Replication-Project/results/RCT/tables/robustness/Alt_main_results_alternatecontrols_PanelB.tex"'})

{com}.                 
. 
.                 
. 
{txt}end of do-file

{com}.         do              "$rep_code/tables/Robustness and stats referred to in paper/Alt_main_results_HTEhusbcopar_alternate_controls.do"
{txt}
{com}. /*******************************************************************************
> ********************************************************************************
> ********************************************************************************
> 
> Purpose:        Robustness      -       Stacked: driving, mobility, labor market outcomes,
>                                                         and independent decision making; HTE (has husband/
>                                                         co-parent)
> 
> Table footnotes: This table generates estimates for our main outcomes interacted
> with 'has husband/co-parent' using an alternate set of controls: we replace the 
> dichotomous controls for age and education with a series of bins for each control, 
> and replace the baseline labor force participation indicator with indicators for 
> baseline employment and unemployment. `Has husband/co-parent' is defined as (a) 
> currently married or (b) divorced/separated with children under 18 in the household. 
> Variations in sample size are due to drop-off from telephone survey; order of 
> survey modules was randomized. All estimates include cohort FEs and individual 
> and household control variables: age, education level, household size, number of cars
> owned by household, and baseline employment. SEs are clustered at household level. 
> * p < 0.1 ** p < 0.05 *** p < 0.01.                                                              
> ********************************************************************************
> ********************************************************************************
> ********************************************************************************/
. eststo clear
{txt}
{com}. 
. * Pull in data:
.         do "$rep_code/1 - Pull in data.do"
{txt}
{com}. /*******************************************************************************
> ********************************************************************************
> ********************************************************************************
> 
> Purpose:                Pull in dataset for paper tables and figures; this dataset 
>                                 combines all three waves and is the final cleaned version. It is 
>                                 in wide format (sample size = 606)
>                                 
> ********************************************************************************
> ********************************************************************************
> *******************************************************************************/
. 
. * Pull in final dataset
. use  "$data/RCT wave 3/Final/Combined_allwaves_final.dta", clear
{txt}
{com}. 
. 
{txt}end of do-file

{com}.         
. * Create global for controls    
. global  controls_HTE_orig i.age_4group_BL miss_age_PAP i.edu_category_BL miss_edu_category ///
>                 household_size miss_household_size one_car mult_cars miss_cars employed_BL ///
>                 unemployed_BL miss_unemployed  
{txt}
{com}.                 
. * Imputation for missing control values
.         * age (PAP version)
.         gen miss_age_PAP = 0
{txt}
{com}.         replace miss_age_PAP = 1 if age_4group==.
{txt}(1 real change made)

{com}.         lab var miss_age_PAP "Missing value for age (PAP version)"
{txt}
{com}.         replace age_4group_BL = 0 if age_4group_BL==.
{txt}(1 real change made)

{com}.         * household_size
.         gen miss_household_size = 0
{txt}
{com}.         replace miss_household_size = 1 if household_size==.
{txt}(19 real changes made)

{com}.         lab var miss_household_size "Missing value for household_size"
{txt}
{com}.         replace household_size = 0 if household_size==.
{txt}(19 real changes made)

{com}.         
.         * Cars
.         * create one missing tag(since missing for the same people)
.         gen miss_cars = 0
{txt}
{com}.         replace miss_cars = 1 if cars==.
{txt}(17 real changes made)

{com}.         lab var miss_cars "Missing value for cars"      
{txt}
{com}.         * dummy for one car
.         replace one_car = 0 if one_car==.
{txt}(17 real changes made)

{com}.         * dummy for 2+ cars
.         replace mult_cars = 0 if mult_cars==.
{txt}(17 real changes made)

{com}. 
.         * Relationship status (updated categories)
.         * create one missing tag (since missing for the same people)
.         gen miss_relationship   = 0
{txt}
{com}.         replace miss_relationship = 1 if rel_status_BL==.
{txt}(4 real changes made)

{com}.         lab var miss_relationship "Missing value for relationship status"
{txt}
{com}.         * married
.         replace married = 0 if married==.
{txt}(4 real changes made)

{com}.         * divorced/separated
.         replace divorced_separated = 0 if divorced_separated==.
{txt}(4 real changes made)

{com}.         * single
.         replace single = 0 if single==.
{txt}(4 real changes made)

{com}.         * widowed
.         replace widowed = 0 if widowed==.
{txt}(4 real changes made)

{com}.         
.         * unemployed_BL
.         gen miss_unemployed_BL = 0 
{txt}
{com}.         replace miss_unemployed_BL = 1 if unemployed_BL==.
{txt}(1 real change made)

{com}.         lab var miss_unemployed_BL "Missing value for unemployed_BL"
{txt}
{com}.         replace unemployed_BL = 0 if unemployed_BL==.
{txt}(1 real change made)

{com}. 
.         * edu_category
.         gen miss_edu_category = 0 
{txt}
{com}.         replace miss_edu_category = 1 if edu_category==.
{txt}(12 real changes made)

{com}.         lab var miss_edu_category "Missing value for edu_category"
{txt}
{com}.         replace edu_category = 0 if edu_category==.
{txt}(12 real changes made)

{com}.                 
.         
. * Restrict data to main follow up
.         keep if endline_start_w3==1
{txt}(105 observations deleted)

{com}.         
. * shorten var name for storage
.         rename share_trips_unaccomp_w3 share_unaccomp
{res}{txt}
{com}.         
. * Set global for table outcomes
.         global  drive_mob_lab s_train_bi_w3 license_w3 drive_any_mo_bi_w3 ///
>                         M4_1_TEXT share_unaccomp employed_w3  unemployed_w3 not_in_LF_w3 ///
>                         empl_jobsearch_w3 no_trips_unaccomp_w3 G1_2_abovemed G1_3_abovemed
{txt}
{com}. 
. * Run models
.                            
.                 foreach var of global drive_mob_lab {c -(}           
{txt}  2{com}. 
.                         reghdfe `var' treatment##i.husb_influence_kids_original_BL $controls_HTE_orig , ///
>                         absorb(randomization_cohort2 )  vce(cluster file_nbr)
{txt}  3{com}.                         eststo `var'_1
{txt}  4{com}.                         
.                         * Test total effect
.                         test _b[1.treatment] + _b[1.treatment#1.husb_influence_kids]=0
{txt}  5{com}.                         estadd scalar b1_b3 = r(p)
{txt}  6{com}.                         
.                         * Store total effect for outcomes in Panel B                    
.                         lincom 1.treatment + 1.treatment#1.husb_influence_kids                          
{txt}  7{com}.                         local totaleff: di %9.3f `r(estimate)'
{txt}  8{com}.                         if `r(p)' < 0.01 {c -(}
{txt}  9{com}.                         local star "\sym{c -(}***{c )-}"
{txt} 10{com}.                         {c )-}
{txt} 11{com}.                         else if `r(p)' < 0.05 {c -(}
{txt} 12{com}.                         local star "\sym{c -(}**{c )-}"
{txt} 13{com}.                         {c )-}
{txt} 14{com}.                         else if `r(p)' < 0.1 {c -(}
{txt} 15{com}.                         local star "\sym{c -(}*{c )-}"
{txt} 16{com}.                         {c )-}
{txt} 17{com}.                         else {c -(}
{txt} 18{com}.                                 local star ""
{txt} 19{com}.                         {c )-}
{txt} 20{com}.                         estadd local total_eff_b  "`totaleff'`star'"
{txt} 21{com}.                         local aux_se: display %5.3f `r(se)'
{txt} 22{com}.                         estadd local total_eff_se "(`aux_se')"
{txt} 23{com}.                 
.                         
.                         * grab control means for each subgroup
.                         sum `var' if e(sample) & treatment==0 & husb_influence_kids_original_BL==0
{txt} 24{com}.                         estadd scalar cmean_nohus = r(mean)
{txt} 25{com}.                         
.                         sum `var' if e(sample) & treatment==0 & husb_influence_kids_original_BL==1
{txt} 26{com}.                         estadd scalar cmean_hus = r(mean)
{txt} 27{com}.                 {c )-}
{res}{txt}({browse "http://scorreia.com/research/hdfe.pdf":MWFE estimator} converged in 1 iterations)
