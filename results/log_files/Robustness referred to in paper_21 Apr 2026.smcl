{com}.         do              "$rep_code/tables/Robustness and stats referred to in paper/Likert versions of index components/Alt_TA10_PanelB_Col5_Likert.do"
{txt}
{com}. /*******************************************************************************
> ********************************************************************************
> ********************************************************************************
> 
> Purpose:                Robustness       -      Alternate Table A10, Panel B, Column 5; Own 
>                                                                 Attitudes Index; Likert version
>         
> Table footnotes: Alternate version of Table A10, Panel B, Column 5, where we use 
> the full likert scale to generate the index outcome. Variations in sample size 
> are due to drop-off from telephone survey; order of survey modules was randomized. 
> All estimates include randomization cohort fixed effects, SEs are clustered at 
> household level. * p < 0.1 ** p < 0.05 *** p < 0.01.    
> ********************************************************************************
> ********************************************************************************
> ********************************************************************************/
. eststo clear
{txt}
{com}. 
. * RUN THESE DO FILES FIRST:
. 
.         do "$rep_code/1 - Pull in data.do"
{txt}
{com}. /*******************************************************************************
> ********************************************************************************
> ********************************************************************************
> 
> Purpose:                Pull in dataset for paper tables and figures; this dataset 
>                                 combines all three waves and is the final cleaned version. It is 
>                                 in wide format (sample size = 606)
>                                 
> ********************************************************************************
> ********************************************************************************
> *******************************************************************************/
. 
. * Pull in final dataset
. use  "$data/RCT wave 3/Final/Combined_allwaves_final.dta", clear
{txt}
{com}. 
. 
{txt}end of do-file

{com}.         
. 
.         
. * Set global for table outcomes
.         global lab  ga_1st_order_likert_sw 
{txt}
{com}. 
.         
. * Run models
.         
.                 * (1) Strata FEs, PAP controls, baseline employment
.                 foreach var of global lab {c -(}             
{txt}  2{com}. 
.                         reghdfe `var' treatment if endline_start_w3==1, ///
>                         absorb(randomization_cohort2)  vce(cluster file_nbr)
{txt}  3{com}.                         eststo `var'
{txt}  4{com}.                         
.                         * grab control mean
.                         sum `var' if e(sample) & treatment==0
{txt}  5{com}.                         estadd scalar cmean = r(mean)
{txt}  6{com}.                         
.                         * grab beta/control mean
.                         local beta: display %4.3f _b[treatment]
{txt}  7{com}.                         local cmean: display %4.3f r(mean)
{txt}  8{com}.                         estadd scalar b_cmean = `beta'/`cmean'
{txt}  9{com}.                         
.                         * P-value 
.                         test treatment = 0 
{txt} 10{com}.                         estadd scalar pval = `r(p)' 
{txt} 11{com}. 
.                         {c )-}
{res}{txt}({browse "http://scorreia.com/research/hdfe.pdf":MWFE estimator} converged in 1 iterations)
{res}
{txt}HDFE Linear regression{col 51}Number of obs{col 67}= {res}       490
